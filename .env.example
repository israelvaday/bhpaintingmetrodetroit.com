# --- Static site (GitHub Pages build) ---
NEXT_EXPORT=1
NEXT_PUBLIC_GH_PAGES=1
NEXT_PUBLIC_SITE_URL=https://bhpaintingmetrodetroit.com
# When Railway hosts the quote API, set this on GH Pages builds:
# NEXT_PUBLIC_QUOTE_API_URL=https://YOUR-RAILWAY-APP.up.railway.app/api/quote

# --- Railway / server build (no NEXT_EXPORT) ---
# Resend delivers mail; Railway only runs the API code (see below).
RESEND_API_KEY=
# Comma-separated. If unset, defaults to both addresses in lib/business.ts
QUOTE_TO_EMAIL=israelvaday97@gmail.com,oren.siyonov@gmail.com
QUOTE_FROM_EMAIL=BH Painting Metro Detroit <quotes@bhpaintingmetrodetroit.com>

# OpenRouter (local scripts only)
OPENROUTER_API_KEY=
OPENROUTER_CHAT_MODEL=google/gemini-2.5-flash
OPENROUTER_IMAGE_MODEL=google/gemini-3-pro-image-preview
